rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid'])
        && data.uid is string && data.uid == request.auth.uid
        && (!data.keys().hasAny(['email']) || data.email == null || (data.email is string && data.email.size() <= 256))
        && (!data.keys().hasAny(['displayName']) || data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (!data.keys().hasAny(['photoURL']) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
        && (!data.keys().hasAny(['avatarSeed']) || data.avatarSeed == null || (data.avatarSeed is string && data.avatarSeed.size() <= 100))
        && (!data.keys().hasAny(['theme']) || data.theme in ['light', 'dark', 'system'])
        && (!data.keys().hasAny(['toolbarPosition']) || data.toolbarPosition in ['top', 'bottom'])
        && (!data.keys().hasAny(['showFloatingMenu']) || data.showFloatingMenu is bool)
        && (!data.keys().hasAny(['showBubbleMenu']) || data.showBubbleMenu is bool)
        && (!data.keys().hasAny(['autoSave']) || data.autoSave is bool)
        && (!data.keys().hasAny(['createdAt']) || data.createdAt == request.time || (resource != null && data.createdAt == resource.data.createdAt))
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt == request.time);
    }

    function isValidPage(data) {
      return data.keys().hasAll(['ownerId', 'title', 'isArchived', 'isPublished'])
        && data.ownerId == request.auth.uid
        && data.title is string && data.title.size() <= 1000
        && data.isArchived is bool
        && data.isPublished is bool
        && (!data.keys().hasAny(['workspaceId']) || (data.workspaceId is string && data.workspaceId.size() <= 128))
        && (!data.keys().hasAny(['icon']) || (data.icon is string && data.icon.size() <= 10))
        && (!data.keys().hasAny(['coverImage']) || (data.coverImage is string && data.coverImage.size() <= 1000))
        && (!data.keys().hasAny(['createdAt']) || data.createdAt == request.time || (resource != null && data.createdAt == resource.data.createdAt))
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt == request.time);
    }

    function isValidUpdate(data) {
      return data.keys().hasAll(['update', 'timestamp', 'userId', 'ownerId', 'isPublished'])
        && data.update is list && data.update.size() <= 1000000
        && (data.timestamp == request.time || (resource != null && data.timestamp == resource.data.timestamp))
        && data.userId == request.auth.uid
        && data.ownerId is string
        && data.isPublished is bool
        && (!data.keys().hasAny(['seq']) || data.seq is int || data.seq is float);
    }

    function isValidPresence(data) {
      return data.keys().hasAll(['uid', 'lastActive', 'ownerId', 'isPublished'])
        && data.uid == request.auth.uid
        && data.lastActive == request.time
        && data.ownerId is string
        && data.isPublished is bool
        && (!data.keys().hasAny(['displayName']) || data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (!data.keys().hasAny(['photoURL']) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
        && (!data.keys().hasAny(['cursorPos']) || data.cursorPos is int);
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'theme', 'email', 'toolbarPosition', 'showFloatingMenu', 'showBubbleMenu', 'avatarSeed', 'updatedAt', 'autoSave']);
    }

    match /pages/{pageId} {
      allow get: if (isSignedIn() && isOwner(existing().ownerId)) || existing().isPublished == true;
      allow list: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || resource.data.isPublished == true;
      
      allow create: if isSignedIn() && isValidId(pageId) && isValidPage(incoming());
      
      allow update: if isSignedIn() && isValidId(pageId) && isOwner(existing().ownerId) && isValidPage(incoming())
        && incoming().ownerId == existing().ownerId; // ownerId is immutable

      allow delete: if isSignedIn() && isValidId(pageId) && isOwner(existing().ownerId);

      // Sub-collections: Updates and Presences
      function canAccessPage(pId) {
        let p = get(/databases/$(database)/documents/pages/$(pId)).data;
        return isOwner(p.ownerId) || p.isPublished == true;
      }

      match /updates/{updateId} {
        allow list, get: if canAccessPage(pageId);
        allow create: if isSignedIn() && isValidId(updateId) && canAccessPage(pageId) && isValidUpdate(incoming());
      }

      match /presences/{uid} {
        allow list, get: if canAccessPage(pageId);
        allow create, update: if isSignedIn() && uid == request.auth.uid && canAccessPage(pageId) && isValidPresence(incoming());
        allow delete: if isSignedIn() && uid == request.auth.uid;
      }

      match /versions/{versionId} {
        allow read: if canAccessPage(pageId);
        allow create: if isSignedIn() && isOwner(get(/databases/$(database)/documents/pages/$(pageId)).data.ownerId);
      }
    }
  }
}
